{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "destaperapido.cl" }],
      "destination": "https://www.destaperapido.cl/:path*",
      "permanent": true
    },
    {
      "source": "/Archivo/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/Blogs/:path*",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/servicios/test",
      "destination": "/servicios",
      "permanent": true
    },
    {
      "source": "/zonas/urbano/ñuñoa",
      "destination": "/zonas/urbano/nunoa",
      "permanent": true
    },
    {
      "source": "/zonas/urbano/%C3%B1u%C3%B1oa",
      "destination": "/zonas/urbano/nunoa",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!api/|_next/|.*\\.).*)",
      "destination": "/:path.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/output.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(webp|avif|jpg|jpeg|png|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
